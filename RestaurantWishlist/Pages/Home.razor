@page "/"

@inject IJSRuntime JS
@inject IRestaurantRepository Repository

<PageTitle>Wishlist Restaurants</PageTitle>

<div class="screen">
    <button class="corner-btn top-left filter-btn" @onclick="OpenFilters">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="44" height="44" style="pointer-events: none;">
            <!-- Slider lines -->
            <line x1="3" y1="7"  x2="21" y2="7"  stroke="#6B5F80" stroke-width="1.75" stroke-linecap="round"/>
            <line x1="3" y1="12" x2="21" y2="12" stroke="#6B5F80" stroke-width="1.75" stroke-linecap="round"/>
            <line x1="3" y1="17" x2="21" y2="17" stroke="#6B5F80" stroke-width="1.75" stroke-linecap="round"/>
            <!-- Knobs -->
            <circle cx="8"  cy="7"  r="2.75" fill="#9B89C4"/>
            <circle cx="15" cy="12" r="2.75" fill="#E8A87C"/>
            <circle cx="10" cy="17" r="2.75" fill="#87B5A2"/>
            <!-- Active filter indicator -->
            @if (_isFiltered)
            {
                <circle cx="20" cy="4" r="2.75" fill="#E07B7B"/>
            }
        </svg>
    </button>
    <button class="corner-btn top-right spin-wheel-btn @(_isSpinning ? "spinning" : "")" @onclick="Spin">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="78" height="78" style="pointer-events: none;">
            <!-- Six colored segments -->
            <path d="M12,12 L12,2 A10,10 0 0,1 20.66,7 Z" fill="#9B89C4"/>
            <path d="M12,12 L20.66,7 A10,10 0 0,1 20.66,17 Z" fill="#E8A87C"/>
            <path d="M12,12 L20.66,17 A10,10 0 0,1 12,22 Z" fill="#C4A96B"/>
            <path d="M12,12 L12,22 A10,10 0 0,1 3.34,17 Z" fill="#87B5A2"/>
            <path d="M12,12 L3.34,17 A10,10 0 0,1 3.34,7 Z" fill="#E07B7B"/>
            <path d="M12,12 L3.34,7 A10,10 0 0,1 12,2 Z" fill="#7BA8E0"/>
            <!-- Outer rim -->
            <circle cx="12" cy="12" r="10" fill="none" stroke="white" stroke-width="0.75"/>
            <!-- Center hub -->
            <circle cx="12" cy="12" r="5" fill="white"/>
            <!-- SPIN label -->
            <text x="12" y="12" text-anchor="middle" dy="0.35em" font-size="3.2" font-weight="800" fill="#2D2040" font-family="sans-serif" letter-spacing="0.3">SPIN</text>
            <!-- Curved spin arrow — dark so it's visible on any segment -->
            <path d="M15.5,2.6 A10,10 0 0,1 21.5,8.5" stroke="#2D2040" stroke-width="2" fill="none" stroke-linecap="round"/>
            <polyline points="19.4,7.1 21.5,8.5 22.2,6.1" stroke="#2D2040" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
    </button>

    @if (VisibleRestaurants.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-icon">🍽️</div>
            <div class="empty-title">No restaurants yet</div>
            <div class="empty-subtitle">Tap ➕ to add your first one</div>
        </div>
    }
    else
    {
        <div class="wheel-container" @ref="WheelRef" @onscroll="OnScroll">
            @for (int i = 0; i < VisibleRestaurants.Count * RepeatCount; i++)
            {
                var r = VisibleRestaurants[i % VisibleRestaurants.Count];
                var isActive = i == SelectedIndex;
                <div class="wheel-item @(isActive ? "active" : "")">
                    @if (isActive)
                    {
                        <div class="left-actions">
                            <button class="side-btn" @onclick="EditSelected">
                                <svg viewBox="0 0 24 24" width="28" height="28" xmlns="http://www.w3.org/2000/svg" style="pointer-events:none">
                                    <g transform="rotate(-45 12 12)">
                                        <rect x="9" y="2" width="6" height="3" rx="1" fill="#E07B7B"/>
                                        <rect x="9" y="5" width="6" height="8" fill="#9B89C4"/>
                                        <rect x="9" y="13" width="6" height="2" fill="#C4A96B"/>
                                        <polygon points="9,15 15,15 12,21" fill="#E8A87C"/>
                                    </g>
                                </svg>
                            </button>
                        </div>
                    }
                    <div class="wheel-text">
                        <div class="wheel-name">@r.Name</div>
                        <div class="wheel-meta">@string.Join(", ", r.Cuisines)</div>
                        <div class="wheel-cost">@r.Cost</div>
                    </div>
                    @if (isActive)
                    {
                        <div class="right-actions">
                            <button class="side-btn" @onclick="DeleteSelected">
                                <svg viewBox="0 0 24 24" width="28" height="28" xmlns="http://www.w3.org/2000/svg" style="pointer-events:none">
                                    <path d="M9 3h6a1 1 0 011 1v1H8V4a1 1 0 011-1z" fill="#C4A96B"/>
                                    <rect x="4" y="5" width="16" height="2.5" rx="1.25" fill="#E07B7B"/>
                                    <path d="M6.5 9l1.3 11c.1.6.6 1 1.2 1h6c.6 0 1.1-.4 1.2-1L17.5 9h-11z" fill="#E07B7B"/>
                                    <line x1="10" y1="11" x2="10.5" y2="19" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
                                    <line x1="12" y1="11" x2="12" y2="19" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
                                    <line x1="14" y1="11" x2="13.5" y2="19" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
                                </svg>
                            </button>
                        </div>
                    }
                </div>
            }
        </div>
    }

    <button class="fab custom-fab" @onclick="AddRestaurant">
        <svg viewBox="0 0 24 24" width="56" height="56" xmlns="http://www.w3.org/2000/svg" style="pointer-events:none">
            <defs><linearGradient id="gadd" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#9B89C4"/><stop offset="100%" stop-color="#E8A87C"/></linearGradient></defs>
            <circle cx="12" cy="12" r="11" fill="url(#gadd)"/>
            <path d="M12 6V18M6 12H18" stroke="white" stroke-width="3" stroke-linecap="round"/>
        </svg>
    </button>
</div>

<AddRestaurantSheet IsVisible="_showAddSheet"
                    OnClose="() => _showAddSheet = false"
                    OnSaved="OnRestaurantAdded" />

<FilterSheet IsVisible="_showFilterSheet"
             ActiveCuisines="_filterCuisines"
             ActiveCosts="_filterCosts"
             OnClose="() => _showFilterSheet = false"
             OnApply="OnFilterApplied" />


<style>
    .screen {
        height: 100vh;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        background: var(--mud-palette-background);
        font-family: 'Roboto', sans-serif;
        max-width: 100vw;
    }

    .corner-btn {
        position: fixed !important;
        z-index: 10;
    }

    .top-left { top: 0.25rem; left: 0.25rem; }
    .top-right { top: 0.25rem; right: 0.25rem; }

    .wheel-container {
        flex: 1;
        overflow-y: scroll;
        overflow-x: hidden;
        scroll-snap-type: y mandatory;
        padding: 40vh 0;
        touch-action: pan-y;
    }

    .wheel-item {
        scroll-snap-align: center;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
        opacity: 0.3;
        transition: transform 0.2s ease, opacity 0.2s ease;
    }

    .wheel-item.active {
        opacity: 1;
        padding: 3.5rem 0;
        transform: scale(1.5);
    }

    .wheel-text {
        min-width: 160px;
        text-align: center;
    }

    .wheel-name {
        font-size: 1.8rem;
        font-weight: 600;
        color: var(--mud-palette-text-primary);
    }

    .wheel-item.active .wheel-name {
        color: var(--mud-palette-primary);
    }

    .wheel-meta {
        font-size: 0.85rem;
        color: var(--mud-palette-text-secondary);
        margin-top: 0.15rem;
    }

    .wheel-cost {
        font-size: 0.75rem;
        color: var(--mud-palette-text-secondary);
        opacity: 0.65;
        margin-top: 0.1rem;
    }

    .left-actions {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.1rem;
        margin-right: 0.5rem;
    }

    .right-actions {
        margin-left: 0.5rem;
    }

    .empty-state {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }

    .empty-icon {
        font-size: 3rem;
        margin-bottom: 0.25rem;
    }

    .empty-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--mud-palette-text-secondary);
    }

    .empty-subtitle {
        font-size: 0.9rem;
        color: var(--mud-palette-text-secondary);
        opacity: 0.7;
    }

    .fab {
        position: fixed !important;
        bottom: 1.5rem !important;
        right: 1.5rem !important;
    }

    .custom-fab {
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
        line-height: 0;
        filter: drop-shadow(0 3px 6px rgba(45,32,64,0.25));
    }

    .side-btn {
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.2rem;
        line-height: 0;
        border-radius: 50%;
    }

    .spin-wheel-btn {
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.5rem;
        line-height: 0;
    }

    .filter-btn {
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.5rem;
        line-height: 0;
    }

    @@keyframes spin-icon {
        0%   { transform: rotate(0deg); }
        100% { transform: rotate(720deg); }
    }

    .spin-wheel-btn.spinning {
        animation: spin-icon 0.8s cubic-bezier(0.2, 0, 0.1, 1);
    }
</style>

@code {
    private const int RepeatCount = 50;

    private ElementReference WheelRef;

    private List<Restaurant> _allRestaurants = new();
    private List<Restaurant> VisibleRestaurants = new();
    private List<Cuisine> _filterCuisines = new();
    private List<Cost> _filterCosts = new();
    private bool _isFiltered => _filterCuisines.Any() || _filterCosts.Any();

    private bool _showAddSheet = false;
    private bool _showFilterSheet = false;
    private bool _isSpinning = false;
    private int _lastRenderedCount = -1;

    private int SelectedIndex = 0;

    private Restaurant? SelectedRestaurant =>
        VisibleRestaurants.Count > 0 ? VisibleRestaurants[SelectedIndex % VisibleRestaurants.Count] : null;

    protected override async Task OnInitializedAsync()
    {
        _allRestaurants = await Repository.GetAllAsync();
        ApplyFilter();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (VisibleRestaurants.Count > 0 && VisibleRestaurants.Count != _lastRenderedCount)
        {
            _lastRenderedCount = VisibleRestaurants.Count;
            SelectedIndex = VisibleRestaurants.Count * (RepeatCount / 2);
            await JS.InvokeVoidAsync("spinWheel.scrollToIndex", WheelRef, SelectedIndex, true);
        }
    }

    private bool _isRecentering = false;

    private async Task OnScroll()
    {
        if (_isRecentering) return;

        SelectedIndex = await JS.InvokeAsync<int>("spinWheel.getCenteredIndex", WheelRef);

        // Silently re-center when within 5 loops of either edge so the list never ends
        var total = VisibleRestaurants.Count * RepeatCount;
        var buffer = VisibleRestaurants.Count * 5;
        if (VisibleRestaurants.Count > 0 && (SelectedIndex < buffer || SelectedIndex > total - buffer))
        {
            _isRecentering = true;
            SelectedIndex = VisibleRestaurants.Count * (RepeatCount / 2) + (SelectedIndex % VisibleRestaurants.Count);
            await JS.InvokeVoidAsync("spinWheel.scrollToIndex", WheelRef, SelectedIndex, true);
            _isRecentering = false;
        }

        StateHasChanged();
    }

    private async Task Spin()
    {
        if (VisibleRestaurants.Count == 0 || _isSpinning) return;

        _isSpinning = true;

        var randomOffset = Random.Shared.Next(VisibleRestaurants.Count);
        var loops = Random.Shared.Next(3, 6);
        var targetIndex = Math.Min(
            SelectedIndex + (loops * VisibleRestaurants.Count) + randomOffset,
            VisibleRestaurants.Count * RepeatCount - 1);

        await JS.InvokeVoidAsync("spinWheel.scrollToIndex", WheelRef, targetIndex);
        await Task.Delay(800);

        _isSpinning = false;
    }

    private void OpenFilters() => _showFilterSheet = true;

    private void OnFilterApplied((List<Cuisine> cuisines, List<Cost> costs) filter)
    {
        _filterCuisines = filter.cuisines;
        _filterCosts = filter.costs;
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        VisibleRestaurants = _allRestaurants
            .Where(r =>
                (!_filterCuisines.Any() || r.Cuisines.Any(c => _filterCuisines.Contains(c))) &&
                (!_filterCosts.Any() || _filterCosts.Contains(r.Cost)))
            .ToList();
    }

    private void AddRestaurant() => _showAddSheet = true;

    private async Task OnRestaurantAdded(Restaurant restaurant)
    {
        await Repository.SaveAsync(restaurant);
        _allRestaurants.Add(restaurant);
        ApplyFilter();
        _showAddSheet = false;
    }

    private void EditSelected()
    {
        //TODO: Open 'edit' page
        Console.WriteLine($"Edit {SelectedRestaurant?.Name}");
    }

    private async Task DeleteSelected()
    {
        if (SelectedRestaurant is null) return;

        await Repository.DeleteAsync(SelectedRestaurant.Id);
        _allRestaurants.Remove(SelectedRestaurant);
        ApplyFilter();
    }

}