@page "/"

@inject IJSRuntime JS
@inject IRestaurantRepository Repository

<PageTitle>Wishlist Restaurants</PageTitle>

<div class="screen">
    <MudIconButton Class="corner-btn top-left" OnClick="OpenFilters" Icon="@Icons.Material.Filled.Tune" Style="color: var(--mud-palette-text-secondary);" />
    <MudIconButton Class="corner-btn top-right" OnClick="Spin" Icon="@Icons.Material.Filled.Casino" Style="color: var(--mud-palette-text-secondary);" />

    @if (VisibleRestaurants.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-icon">🍽️</div>
            <div class="empty-title">No restaurants yet</div>
            <div class="empty-subtitle">Tap ➕ to add your first one</div>
        </div>
    }
    else
    {
        <div class="wheel-container" @ref="WheelRef" @onscroll="OnScroll">
            @for (int i = 0; i < VisibleRestaurants.Count * RepeatCount; i++)
            {
                var r = VisibleRestaurants[i % VisibleRestaurants.Count];
                var isActive = i == SelectedIndex;
                <div class="wheel-item @(isActive ? "active" : "")">
                    @if (isActive)
                    {
                        <MudIconButton Class="side-btn" OnClick="EditSelected" Icon="@Icons.Material.Filled.Edit" Size="Size.Small" />
                    }
                    <div class="wheel-text">
                        <div class="wheel-name">@r.Name</div>
                        <div class="wheel-meta">@string.Join(", ", r.Cuisines)</div>
                    </div>
                    @if (isActive)
                    {
                        <MudIconButton Class="side-btn danger" OnClick="DeleteSelected" Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small" />
                    }
                </div>
            }
        </div>
    }

    <MudFab Class="fab" OnClick="AddRestaurant" StartIcon="@Icons.Material.Filled.Add" Color="Color.Primary" />
</div>

<AddRestaurantSheet IsVisible="_showAddSheet"
                    OnClose="() => _showAddSheet = false"
                    OnSaved="OnRestaurantAdded" />

<style>
    .screen {
        height: 100vh;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        background: var(--mud-palette-background);
        font-family: 'Roboto', sans-serif;
    }

    .corner-btn {
        position: fixed !important;
        z-index: 10;
    }

    .top-left { top: 0.25rem; left: 0.25rem; }
    .top-right { top: 0.25rem; right: 0.25rem; }

    .wheel-container {
        flex: 1;
        overflow-y: scroll;
        scroll-snap-type: y mandatory;
        padding: 40vh 0;
    }

    .wheel-item {
        scroll-snap-align: center;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
        opacity: 0.3;
        transition: transform 0.2s ease, opacity 0.2s ease;
    }

    .wheel-item.active {
        opacity: 1;
        padding: 3.5rem 0;
        transform: scale(1.5);
    }

    .wheel-text {
        min-width: 160px;
        text-align: center;
    }

    .wheel-name {
        font-size: 1.8rem;
        font-weight: 600;
        color: var(--mud-palette-text-primary);
    }

    .wheel-item.active .wheel-name {
        color: var(--mud-palette-primary);
    }

    .wheel-meta {
        font-size: 0.85rem;
        color: var(--mud-palette-text-secondary);
        margin-top: 0.15rem;
    }

    .side-btn {
        flex-shrink: 0;
        margin: 0 0.75rem;
        border-radius: 50% !important;
        color: var(--mud-palette-text-secondary) !important;
    }

    .side-btn.danger {
        color: #C2485A !important;
    }

    .empty-state {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }

    .empty-icon {
        font-size: 3rem;
        margin-bottom: 0.25rem;
    }

    .empty-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--mud-palette-text-secondary);
    }

    .empty-subtitle {
        font-size: 0.9rem;
        color: var(--mud-palette-text-secondary);
        opacity: 0.7;
    }

    .fab {
        position: fixed !important;
        bottom: 1.5rem !important;
        right: 1.5rem !important;
    }
</style>

@code {
    private const int RepeatCount = 50;

    private ElementReference WheelRef;

    //TODO: Replace this with an 'all' list and a 'filtered' list that pulls from the local DB and applies a filter
    private List<Restaurant> VisibleRestaurants = new();
    private bool _showAddSheet = false;
    private int _lastRenderedCount = -1;

    private int SelectedIndex = 0;

    private Restaurant? SelectedRestaurant =>
        VisibleRestaurants.Count > 0 ? VisibleRestaurants[SelectedIndex % VisibleRestaurants.Count] : null;

    protected override async Task OnInitializedAsync()
    {
        VisibleRestaurants = await Repository.GetAllAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (VisibleRestaurants.Count > 0 && VisibleRestaurants.Count != _lastRenderedCount)
        {
            _lastRenderedCount = VisibleRestaurants.Count;
            SelectedIndex = VisibleRestaurants.Count * (RepeatCount / 2);
            await JS.InvokeVoidAsync("spinWheel.scrollToIndex", WheelRef, SelectedIndex, true);
        }
    }

    private bool _isRecentering = false;

    private async Task OnScroll()
    {
        if (_isRecentering) return;

        SelectedIndex = await JS.InvokeAsync<int>("spinWheel.getCenteredIndex", WheelRef);

        // Silently re-center when within 5 loops of either edge so the list never ends
        var total = VisibleRestaurants.Count * RepeatCount;
        var buffer = VisibleRestaurants.Count * 5;
        if (VisibleRestaurants.Count > 0 && (SelectedIndex < buffer || SelectedIndex > total - buffer))
        {
            _isRecentering = true;
            SelectedIndex = VisibleRestaurants.Count * (RepeatCount / 2) + (SelectedIndex % VisibleRestaurants.Count);
            await JS.InvokeVoidAsync("spinWheel.scrollToIndex", WheelRef, SelectedIndex, true);
            _isRecentering = false;
        }

        StateHasChanged();
    }

    private async Task Spin()
    {
        if (VisibleRestaurants.Count == 0) return;

        var randomOffset = Random.Shared.Next(VisibleRestaurants.Count);
        var loops = Random.Shared.Next(3, 6);
        var targetIndex = Math.Min(
            SelectedIndex + (loops * VisibleRestaurants.Count) + randomOffset,
            VisibleRestaurants.Count * RepeatCount - 1);

        await JS.InvokeVoidAsync("spinWheel.scrollToIndex", WheelRef, targetIndex);
    }

    private void OpenFilters()
    {
        //TODO: Open 'filter' menu
        Console.WriteLine("Open filter");
    }

    private void AddRestaurant() => _showAddSheet = true;

    private async Task OnRestaurantAdded(Restaurant restaurant)
    {
        await Repository.SaveAsync(restaurant);
        VisibleRestaurants.Add(restaurant);
        _showAddSheet = false;
    }

    private void EditSelected()
    {
        //TODO: Open 'edit' page
        Console.WriteLine($"Edit {SelectedRestaurant?.Name}");
    }

    private void DeleteSelected()
    {
        if (SelectedRestaurant is null) return;

        VisibleRestaurants.RemoveAt(SelectedIndex % VisibleRestaurants.Count);
    }

}