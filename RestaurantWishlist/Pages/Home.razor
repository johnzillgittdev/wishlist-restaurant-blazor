@page "/"

@inject IJSRuntime JS
@inject IRestaurantRepository Repository

<PageTitle>Wishlist Restaurants</PageTitle>

<div class="screen">
    <button class="corner-btn top-left" @onclick="OpenFilters">⚙️</button>
    <button class="corner-btn top-right" @onclick="Spin">🎰</button>

    @if (VisibleRestaurants.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-icon">🍽️</div>
            <div class="empty-title">No restaurants yet</div>
            <div class="empty-subtitle">Tap ➕ to add your first one</div>
        </div>
    }
    else
    {
        <div class="wheel-container" @ref="WheelRef" @onscroll="OnScroll">
            @for (int i = 0; i < VisibleRestaurants.Count * RepeatCount; i++)
            {
                var r = VisibleRestaurants[i % VisibleRestaurants.Count];
                var isActive = i == SelectedIndex;
                <div class="wheel-item @(isActive ? "active" : "")">
                    @if (isActive)
                    {
                        <button class="side-btn" @onclick="EditSelected">✏️</button>
                    }
                    <div class="wheel-text">
                        <div class="wheel-name">@r.Name</div>
                        <div class="wheel-meta">@string.Join(", ", r.Cuisines)</div>
                    </div>
                    @if (isActive)
                    {
                        <button class="side-btn danger" @onclick="DeleteSelected">🗑️</button>
                    }
                </div>
            }
        </div>
    }

    <button class="fab" @onclick="AddRestaurant">➕</button>
</div>

<AddRestaurantSheet IsVisible="_showAddSheet"
                    OnClose="() => _showAddSheet = false"
                    OnSaved="OnRestaurantAdded" />

<style>
    .screen {
        height: 100vh;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .corner-btn {
        position: fixed;
        background: none;
        border: none;
        font-size: 1.4rem;
        padding: 1rem;
        cursor: pointer;
        z-index: 10;
    }

    .top-left { top: 0; left: 0; }
    .top-right { top: 0; right: 0; }

    .wheel-container {
        flex: 1;
        overflow-y: scroll;
        scroll-snap-type: y mandatory;
        padding: 40vh 0;
    }

    .wheel-item {
        scroll-snap-align: center;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
        opacity: 0.4;
        transition: transform 0.2s ease, opacity 0.2s ease;
    }

    .wheel-item.active {
        opacity: 1;
        padding: 3.5rem 0;
        transform: scale(1.5);
    }

    .wheel-text {
        min-width: 160px;
        text-align: center;
    }

    .wheel-name {
        font-size: 1.8rem;
        font-weight: 600;
    }

    .wheel-meta {
        font-size: 0.9rem;
        color: #666;
    }

    .side-btn {
        flex-shrink: 0;
        margin: 0 1.5rem;
        padding: 0.4rem 0.6rem;
        border-radius: 8px;
        background: none;
        border: 1px solid #ccc;
        font-size: 1rem;
        cursor: pointer;
    }

    .side-btn.danger {
        background: #ffdddd;
        border-color: #f5a5a5;
    }

    .empty-state {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        color: #aaa;
    }

    .empty-icon {
        font-size: 3rem;
        margin-bottom: 0.25rem;
    }

    .empty-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: #888;
    }

    .empty-subtitle {
        font-size: 0.9rem;
    }

    .fab {
        position: fixed;
        bottom: 1.5rem;
        right: 1.5rem;
        width: 56px;
        height: 56px;
        border-radius: 50%;
        font-size: 1.6rem;
        border: 1px solid #ccc;
        background: #f5f5f5;
        cursor: pointer;
    }
</style>

@code {
    private const int RepeatCount = 50;

    private ElementReference WheelRef;

    //TODO: Replace this with an 'all' list and a 'filtered' list that pulls from the local DB and applies a filter
    private List<Restaurant> VisibleRestaurants = new();
    private bool _showAddSheet = false;
    private int _lastRenderedCount = -1;

    private int SelectedIndex = 0;

    private Restaurant? SelectedRestaurant =>
        VisibleRestaurants.Count > 0 ? VisibleRestaurants[SelectedIndex % VisibleRestaurants.Count] : null;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (VisibleRestaurants.Count > 0 && VisibleRestaurants.Count != _lastRenderedCount)
        {
            _lastRenderedCount = VisibleRestaurants.Count;
            SelectedIndex = VisibleRestaurants.Count * (RepeatCount / 2);
            await JS.InvokeVoidAsync("spinWheel.scrollToIndex", WheelRef, SelectedIndex, true);
        }
    }

    private async Task OnScroll()
    {
        SelectedIndex = await JS.InvokeAsync<int>("spinWheel.getCenteredIndex", WheelRef);
        StateHasChanged();
    }

    private async Task Spin()
    {
        if (VisibleRestaurants.Count == 0) return;

        var randomOffset = Random.Shared.Next(VisibleRestaurants.Count);
        var loops = Random.Shared.Next(3, 6);
        var targetIndex = Math.Min(
            SelectedIndex + (loops * VisibleRestaurants.Count) + randomOffset,
            VisibleRestaurants.Count * RepeatCount - 1);

        await JS.InvokeVoidAsync("spinWheel.scrollToIndex", WheelRef, targetIndex);
    }

    private void OpenFilters()
    {
        //TODO: Open 'filter' menu
        Console.WriteLine("Open filter");
    }

    private void AddRestaurant() => _showAddSheet = true;

    private async Task OnRestaurantAdded(Restaurant restaurant)
    {
        await Repository.SaveAsync(restaurant);
        VisibleRestaurants.Add(restaurant);
        _showAddSheet = false;
    }

    private void EditSelected()
    {
        //TODO: Open 'edit' page
        Console.WriteLine($"Edit {SelectedRestaurant?.Name}");
    }

    private void DeleteSelected()
    {
        if (SelectedRestaurant is null) return;

        VisibleRestaurants.RemoveAt(SelectedIndex % VisibleRestaurants.Count);
    }

}