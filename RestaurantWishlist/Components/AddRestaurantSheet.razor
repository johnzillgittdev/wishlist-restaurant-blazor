@using System.Text.RegularExpressions

@if (IsVisible)
{
    <div class="sheet-backdrop" @onclick="Close"></div>
    <div class="sheet" @onclick:stopPropagation>
        <div class="sheet-handle"></div>
        <h2 class="sheet-title">Add Restaurant</h2>

        <div class="field">
            <MudTextField @bind-Value="_name"
                          Label="Restaurant name"
                          Variant="Variant.Outlined"
                          Immediate="true"
                          FullWidth="true" />
        </div>

        <div class="field">
            <div class="field-label">Cuisine</div>
            <div class="chip-grid">
                @foreach (var cuisine in Enum.GetValues<Cuisine>())
                {
                    var c = cuisine;
                    var isSelected = _selectedCuisines.Contains(c);
                    <button class="chip @(isSelected ? "chip-selected" : "")" @onclick="() => ToggleCuisine(c)">
                        @FormatCuisine(c)
                    </button>
                }
            </div>
        </div>

        <div class="sheet-actions">
            <MudButton Variant="Variant.Outlined"
                       OnClick="Close"
                       FullWidth="true"
                       Style="border-color: var(--mud-palette-lines-default); color: var(--mud-palette-text-secondary);">
                Cancel
            </MudButton>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="Save"
                       Disabled="@(!CanSave)"
                       FullWidth="true">
                Add
            </MudButton>
        </div>
    </div>
}

<style>
    .sheet-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(45, 32, 64, 0.45);
        z-index: 100;
    }

    .sheet {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        background: var(--mud-palette-surface);
        border-radius: 20px 20px 0 0;
        padding: 1rem 1.5rem 2.5rem;
        z-index: 101;
        box-shadow: 0 -6px 32px rgba(45, 32, 64, 0.18);
    }

    .sheet-handle {
        width: 40px;
        height: 4px;
        background: var(--mud-palette-lines-default);
        border-radius: 2px;
        margin: 0 auto 1.25rem;
    }

    .sheet-title {
        margin: 0 0 1.25rem;
        font-size: 1.2rem;
        font-weight: 600;
        color: var(--mud-palette-text-primary);
    }

    .field {
        margin-bottom: 1rem;
    }

    .field-label {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--mud-palette-text-secondary);
        margin-bottom: 0.5rem;
    }

    .chip-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .chip {
        padding: 0.35rem 0.85rem;
        border-radius: 20px;
        border: none;
        font-size: 0.82rem;
        font-weight: 500;
        cursor: pointer;
        transition: transform 0.1s ease, background 0.15s ease;
        background: #4A3F5C;
        color: #FAF7FF;
    }

    .chip.chip-selected {
        background: var(--mud-palette-secondary);
        color: var(--mud-palette-text-primary);
    }

    .chip:active {
        transform: scale(0.93);
    }

    .sheet-actions {
        display: flex;
        gap: 0.75rem;
        margin-top: 1.5rem;
    }
</style>

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<Restaurant> OnSaved { get; set; }

    private string _name = string.Empty;
    private List<Cuisine> _selectedCuisines = new();

    private bool CanSave => !string.IsNullOrWhiteSpace(_name) && _selectedCuisines.Any();

    private void ToggleCuisine(Cuisine cuisine)
    {
        if (_selectedCuisines.Contains(cuisine))
            _selectedCuisines.Remove(cuisine);
        else
            _selectedCuisines.Add(cuisine);
    }

    private async Task Save()
    {
        if (!CanSave) return;
        var restaurant = new Restaurant(_name.Trim(), new List<Cuisine>(_selectedCuisines));
        await OnSaved.InvokeAsync(restaurant);
        Reset();
    }

    private async Task Close()
    {
        Reset();
        await OnClose.InvokeAsync();
    }

    private void Reset()
    {
        _name = string.Empty;
        _selectedCuisines.Clear();
    }

    private static string FormatCuisine(Cuisine c) =>
        Regex.Replace(c.ToString(), "(?<=[a-z])([A-Z])", " $1");
}
